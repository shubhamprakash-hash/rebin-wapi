# ==========================================
# RebinChat - Environment Configuration
# ==========================================

# Server
PORT=4000
JWT_SECRET=change_this_to_a_long_random_secret_string

# ==========================================
# META / WHATSAPP APP-LEVEL CREDENTIALS
# (One-time setup at business.facebook.com + developers.facebook.com
#  as described in Section 2 of the blueprint)
# ==========================================

# From developers.facebook.com > Your App > Settings > Basic
META_APP_ID=
META_APP_SECRET=

# From developers.facebook.com > Your App > WhatsApp > Embedded Signup
# (Configuration ID created when you set up Embedded Signup)
META_CONFIG_ID=

# Any string you choose. Enter this EXACT value in Meta's Webhook
# configuration screen under "Verify Token"
META_WEBHOOK_VERIFY_TOKEN=rebinchat_verify_token

# Graph API version
META_GRAPH_VERSION=v20.0
